// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"] // この行を追加！
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Facility {
  id                            Int      @id @default(autoincrement())
  name                          String   // 最大30文字（アプリケーションレベルで制限）
  positionName                  String?  // 最大30文字（アプリケーションレベルで制限）
  positionHolderName            String?  // 最大30文字（アプリケーションレベルで制限）
  sortOrder                     Int      @default(0)
  useSameOrderForDisplayAndPrint Boolean  @default(true)  // true: 表示順を印刷にも使用
  useUnitOrderForPrint          Boolean  @default(true)   // true: 印刷時にユニット順を適用
  residentDisplaySortMode       String?  // 'manual' | 'aiueo' | null(aiueo扱い)
  residentPrintSortMode         String?  // 'manual' | 'aiueo' | null(aiueo扱い)
  noticeTemplateNormal          String?  // 【通常】預り金明細書のお知らせテンプレート（最大100文字）
  noticeTemplateMoveOut         String?  // 【退居】預り金明細書のお知らせテンプレート（最大100文字）
  isActive                      Boolean  @default(true)
  units                         Unit[]
  residents                     Resident[]
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  // パフォーマンス最適化のためのインデックス
  // アクティブな施設をsortOrder順で取得するクエリを高速化
  @@index([isActive, sortOrder])
}

model Unit {
  id               Int        @id @default(autoincrement())
  facilityId       Int
  name             String     // 最大30文字（アプリケーションレベルで制限）
  capacity         Int?       // 定員数（NULL=定員管理なし）
  displaySortOrder Int?       // 表示順（NULL=従来通りid順）
  printSortOrder   Int?       // 印刷順（NULL=従来通りid順）
  isActive         Boolean    @default(true)
  facility         Facility   @relation(fields: [facilityId], references: [id])
  residents        Resident[]
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // パフォーマンス最適化のためのインデックス
  // 施設別のアクティブなユニットを取得するクエリを高速化
  @@index([facilityId, isActive])
}

model Resident {
  id                    Int           @id @default(autoincrement())
  facilityId            Int
  unitId                Int
  name                  String        // 最大30文字（アプリケーションレベルで制限）
  nameFurigana          String?       // ふりがな（最大50文字、ひらがな・ー・・のみ、オプション）
  displaySortOrder      Int?          // 表示順（NULL=従来通りid順）
  printSortOrder        Int?          // 印刷順（NULL=従来通りid順）
  displayNamePrefix     String?       // 利用者名の前に表示する文言（最大10文字）
  namePrefixDisplayOption String?     // "screen_only" | "print_only" | "none"
  startDate             DateTime?
  endDate    DateTime?
  isActive   Boolean      @default(true)
  facility   Facility     @relation(fields: [facilityId], references: [id])
  unit       Unit         @relation(fields: [unitId], references: [id])
  transactions Transaction[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  // パフォーマンス最適化のためのインデックス
  // 施設別のアクティブな利用者を取得するクエリを高速化
  @@index([facilityId, isActive, endDate])
}

model Transaction {
  id              Int          @id @default(autoincrement())
  residentId      Int
  transactionDate DateTime
  transactionType String       // "in", "out", "correct_in", "correct_out"
  amount          Float
  description     String?      // 最大100文字（アプリケーションレベルで制限）
  payee           String?      // 最大30文字（アプリケーションレベルで制限）支払先
  reason          String?      // 最大100文字（アプリケーションレベルで制限）訂正入力時の理由
  resident        Resident     @relation(fields: [residentId], references: [id])
  createdAt       DateTime     @default(now())

  // パフォーマンス最適化のためのインデックス
  // 利用者別の取引を日付でフィルタリングするクエリを高速化
  @@index([residentId, transactionDate])
  // 日付範囲でのフィルタリングを高速化（前月残高計算など）
  @@index([transactionDate])
}

